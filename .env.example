# =============================================================================
# ProofForge — Root Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit your real .env to version control.
# =============================================================================

# ---- Database ---------------------------------------------------------------
# PostgreSQL (production / Docker Compose)
DATABASE_URL=postgresql+asyncpg://skillledger:skillledger@localhost:5432/skillledger

# SQLite (local dev, no Docker required)
# DATABASE_URL=sqlite+aiosqlite:///./skillledger.db

# ---- GitHub OAuth -----------------------------------------------------------
# Create an OAuth App at: https://github.com/settings/developers
# Authorization callback URL (dev): http://localhost:8000/api/v1/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ---- JWT --------------------------------------------------------------------
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Session / Cookies ------------------------------------------------------
SESSION_COOKIE_NAME=skillledger_session
REFRESH_COOKIE_NAME=skillledger_refresh
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ---- URLs -------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ---- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# ---- App --------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- AI API Keys ------------------------------------------------------------
# Google Gemini (optional — for future Gemini integrations)
GEMINI_API_KEY=your_gemini_api_key_here

# Zhipu AI GLM-4 Flash — Used by the GLM Skill Extraction Service
# Get your key at: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here
