# =============================================================================
# ProofForge — Backend Environment Variables Template
# Copy this file to backend/.env and fill in your values.
# =============================================================================

# ---- Database ---------------------------------------------------------------
# SQLite (local dev — no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./skillledger.db

# PostgreSQL (Docker Compose / production)
# DATABASE_URL=postgresql+asyncpg://skillledger:skillledger@localhost:5432/skillledger

# ---- GitHub OAuth -----------------------------------------------------------
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ---- JWT --------------------------------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Session / Cookies ------------------------------------------------------
SESSION_COOKIE_NAME=skillledger_session
REFRESH_COOKIE_NAME=skillledger_refresh
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ---- URLs -------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ---- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# ---- App --------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- AI API Keys ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GLM_API_KEY=your_glm_api_key_here
